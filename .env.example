# ============================================================
#  Paystack configuration
#  Copy this file to ".env.local" for local development.
#  In production, set these in Vercel → Project → Settings → Environment Variables.
#  NEVER commit real keys to Git. (.env.local is git-ignored.)
# ============================================================

# Public key — safe to expose in the browser (starts with pk_)
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Secret key — SERVER ONLY. Keep private. (starts with sk_)
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Currency code for charges
PAYSTACK_CURRENCY=KES
